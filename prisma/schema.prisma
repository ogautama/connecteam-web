// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  agent
  leader
}

enum Position {
  Agent
  AAB
  AB
}

enum UserStatus {
  active
  inactive
}

// id is Supabase's auth.users.id (a UUID) — set by the on_auth_user_created
// trigger, not originated by Prisma. No @default here.
model User {
  id           String     @id
  email        String     @unique
  name         String
  role         Role       @default(agent)
  createdAt    DateTime   @default(now())

  position     Position   @default(Agent)
  status       UserStatus @default(active)
  inviteCode   String     @unique @default(cuid())

  recruiterId  String?
  recruiter    User?      @relation("Recruiter", fields: [recruiterId], references: [id])
  recruits     User[]     @relation("Recruiter")
  applicants   Applicant[]
}

// Created by a leader (Plan 02c) before the invited person ever signs in.
// Consumed (row deleted) by the on_auth_user_created trigger once that
// email completes Google sign-in and a matching User row is created.
// recruiterId/invitedBy are nullable only to bootstrap the very first
// (root) leader, who has no recruiter and wasn't invited by anyone — that
// row is inserted directly (seed script / Prisma Studio), same as root
// User.recruiterId always having been nullable. Every invite created
// through Plan 02c's UI sets both.
model PendingInvite {
  id          String   @id @default(cuid())
  email       String   @unique
  recruiterId String?
  role        Role     @default(agent)
  invitedBy   String?
  createdAt   DateTime @default(now())
}

enum LeadSource {
  calculator
  disc
}

model Lead {
  id        String     @id @default(cuid())
  source    LeadSource
  name      String
  contact   String
  inputs    Json
  result    Json
  createdAt DateTime   @default(now())
}

enum ApplicantStatus {
  submitted
  accepted
  rejected
}

// enrolledUserId dropped (Plan 15b): account creation now happens
// exclusively through the leader-driven pending-invite flow, not by
// promoting an Applicant into a User — accepted stays a record of the
// leader's decision with no side effect on User.
model Applicant {
  id             String          @id @default(cuid())
  name           String
  email          String
  phone          String
  dob            DateTime
  idCardPhotoKey String
  recruiterId    String
  recruiter      User            @relation(fields: [recruiterId], references: [id])
  status         ApplicantStatus @default(submitted)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}
