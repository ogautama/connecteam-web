# Supabase Postgres — pooled connection (app runtime, transaction-mode
# pooler, port 6543). Create a project at supabase.com, then copy this from
# Project Settings > Database > Connect. Percent-encode any @, /, :, #
# characters in the password.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Postgres — unpooled connection (port 5432), used only by
# `prisma migrate`/`prisma db seed` — Supabase's pooler doesn't support the
# prepared statements migrations need.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase project URL — not secret, safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# Supabase Publishable key (sb_publishable_...) — Settings > API Keys. Safe
# for the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Supabase Secret key (sb_secret_...) — Settings > API Keys. Server-only,
# never expose to the client. Not yet used by app code as of Plan 02b —
# reserved for the invite-lookup/profile-creation trigger's elevated
# access if a server-side Admin API call is ever needed.
SUPABASE_SERVICE_ROLE_KEY=""

# prisma/seed.ts fixtures: real Google account emails you control, used to
# manually verify the Google OAuth + pending-invite gate end to end. Each
# must also be added to the Google OAuth consent screen's test-user
# allowlist while it's in Testing publishing status.
SEED_LEADER_EMAIL=""
SEED_AGENT1_EMAIL=""
SEED_AGENT2_EMAIL=""
